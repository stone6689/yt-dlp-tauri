{
  "schemaVersion": 1,
  "targets": [
    "win-x64",
    "macos-x64",
    "macos-arm64"
  ],
  "approvedHosts": [
    "api.github.com",
    "github.com",
    "release-assets.githubusercontent.com",
    "objects.githubusercontent.com",
    "ffmpeg.martin-riedl.de"
  ],
  "sources": [
    {
      "id": "yt-dlp",
      "adapter": "github-release",
      "repository": "yt-dlp/yt-dlp",
      "selection": "latest-stable",
      "assets": [
        {
          "target": "win-x64",
          "assetName": "yt-dlp.exe",
          "kind": "file",
          "members": [
            {
              "tool": "yt-dlp",
              "path": "Tools/win-x64/yt-dlp/yt-dlp.exe",
              "licenseNotes": "Official Windows standalone executable; the combined PyInstaller work is GPLv3+."
            }
          ]
        },
        {
          "target": "macos-x64",
          "assetName": "yt-dlp_macos",
          "kind": "file",
          "members": [
            {
              "tool": "yt-dlp",
              "path": "Tools/macos-x64/yt-dlp/yt-dlp",
              "licenseNotes": "Official macOS standalone executable; the combined PyInstaller work is GPLv3+."
            }
          ]
        },
        {
          "target": "macos-arm64",
          "assetName": "yt-dlp_macos",
          "kind": "file",
          "members": [
            {
              "tool": "yt-dlp",
              "path": "Tools/macos-arm64/yt-dlp/yt-dlp",
              "licenseNotes": "Official macOS standalone executable; the combined PyInstaller work is GPLv3+."
            }
          ]
        }
      ]
    },
    {
      "id": "deno",
      "adapter": "github-release",
      "repository": "denoland/deno",
      "selection": "latest-stable",
      "assets": [
        {
          "target": "win-x64",
          "assetName": "deno-x86_64-pc-windows-msvc.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "deno",
              "path": "Tools/win-x64/deno/deno.exe",
              "archivePathSuffix": "deno.exe",
              "licenseNotes": "Deno is distributed under the MIT license and provides the JavaScript runtime for yt-dlp EJS support."
            }
          ]
        },
        {
          "target": "macos-x64",
          "assetName": "deno-x86_64-apple-darwin.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "deno",
              "path": "Tools/macos-x64/deno/deno",
              "archivePathSuffix": "deno",
              "licenseNotes": "Deno is distributed under the MIT license and provides the JavaScript runtime for yt-dlp EJS support."
            }
          ]
        },
        {
          "target": "macos-arm64",
          "assetName": "deno-aarch64-apple-darwin.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "deno",
              "path": "Tools/macos-arm64/deno/deno",
              "archivePathSuffix": "deno",
              "licenseNotes": "Deno is distributed under the MIT license and provides the JavaScript runtime for yt-dlp EJS support."
            }
          ]
        }
      ]
    },
    {
      "id": "ffmpeg-windows",
      "adapter": "github-release",
      "repository": "yt-dlp/FFmpeg-Builds",
      "selection": "previous-complete-month",
      "assets": [
        {
          "target": "win-x64",
          "assetPattern": "^ffmpeg-N-[0-9]+-g[a-f0-9]+-win64-gpl\\.zip$",
          "kind": "zip",
          "members": [
            {
              "tool": "ffmpeg",
              "path": "Tools/win-x64/ffmpeg/bin/ffmpeg.exe",
              "archivePathSuffix": "bin/ffmpeg.exe",
              "licenseNotes": "GPL build recommended by yt-dlp; redistribution requires the applicable GPL notices and corresponding-source availability."
            },
            {
              "tool": "ffprobe",
              "path": "Tools/win-x64/ffmpeg/bin/ffprobe.exe",
              "archivePathSuffix": "bin/ffprobe.exe",
              "licenseNotes": "Distributed from the same GPL FFmpeg build as ffmpeg.exe."
            }
          ]
        }
      ]
    },
    {
      "id": "ffmpeg-macos-x64",
      "adapter": "redirect-release",
      "selection": "latest-redirect",
      "assets": [
        {
          "target": "macos-x64",
          "url": "https://ffmpeg.martin-riedl.de/redirect/latest/macos/amd64/release/ffmpeg.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "ffmpeg",
              "path": "Tools/macos-x64/ffmpeg/bin/ffmpeg",
              "archivePathSuffix": "ffmpeg",
              "licenseNotes": "Static release build for macOS Intel from Martin Riedl's FFmpeg build server."
            }
          ]
        },
        {
          "target": "macos-x64",
          "url": "https://ffmpeg.martin-riedl.de/redirect/latest/macos/amd64/release/ffprobe.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "ffprobe",
              "path": "Tools/macos-x64/ffmpeg/bin/ffprobe",
              "archivePathSuffix": "ffprobe",
              "licenseNotes": "Static release build for macOS Intel from Martin Riedl's FFmpeg build server."
            }
          ]
        }
      ]
    },
    {
      "id": "ffmpeg-macos-arm64",
      "adapter": "redirect-release",
      "selection": "latest-redirect",
      "assets": [
        {
          "target": "macos-arm64",
          "url": "https://ffmpeg.martin-riedl.de/redirect/latest/macos/arm64/release/ffmpeg.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "ffmpeg",
              "path": "Tools/macos-arm64/ffmpeg/bin/ffmpeg",
              "archivePathSuffix": "ffmpeg",
              "licenseNotes": "Static release build for macOS Apple Silicon from Martin Riedl's FFmpeg build server."
            }
          ]
        },
        {
          "target": "macos-arm64",
          "url": "https://ffmpeg.martin-riedl.de/redirect/latest/macos/arm64/release/ffprobe.zip",
          "kind": "zip",
          "members": [
            {
              "tool": "ffprobe",
              "path": "Tools/macos-arm64/ffmpeg/bin/ffprobe",
              "archivePathSuffix": "ffprobe",
              "licenseNotes": "Static release build for macOS Apple Silicon from Martin Riedl's FFmpeg build server."
            }
          ]
        }
      ]
    }
  ]
}
